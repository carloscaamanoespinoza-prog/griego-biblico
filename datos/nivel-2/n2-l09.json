{
  "id": "n2-l09",
  "nivel": 2,
  "numero": 9,
  "titulo": "Modo Optativo: Deseos y Contrafácticas",
  "subtitulo": "El modo de lo deseado y lo improbable",
  "descripcion": "El optativo expresa deseos y situaciones contrafácticas (contrarias a la realidad). Es menos frecuente que el subjuntivo pero tiene usos muy específicos y poéticamente significativos.",
  "duracionEstimada": 35,
  "prerequisitos": [
    "n2-l08"
  ],
  "objetivos": [
    "Entender el optativo como modo de deseo y contrafacticidad",
    "Reconocer la formación del optativo (-οι-, -αι-)",
    "Conjugar el optativo en diferentes tiempos y voces",
    "Comprender sus usos principales en el NT"
  ],
  "secciones": [
    {
      "id": "optativo-intro",
      "tipo": "explicacion",
      "titulo": "El Optativo: El Modo del Deseo",
      "contenido": [
        {
          "tipo": "parrafo",
          "texto": "El optativo presenta una acción como deseada o como contrafáctica (algo que contradice la realidad actual). Es el modo más 'irrealista', el modo de lo que QUISIÉRAMOS que fuera."
        },
        {
          "tipo": "titulo-seccion",
          "nivel": 4,
          "texto": "Optativo vs. Subjuntivo"
        },
        {
          "tipo": "lista",
          "items": [
            "SUBJUNTIVO: 'si ocurriera X' (potencialmente posible en el futuro)",
            "OPTATIVO: 'ojalá que X' o 'si (pero no) X' (contrafáctico, irrealista)"
          ]
        },
        {
          "tipo": "cita",
          "texto": "μὴ γένοιτο",
          "transliteracion": "mē genoito",
          "traduccion": "¡Dios no lo permita!, ¡Que no sea! (ojalá que no)",
          "referencia": "Romanos 3:4",
          "clase": "normal"
        }
      ]
    },
    {
      "id": "optativo-formacion",
      "tipo": "explicacion",
      "titulo": "Formación del Optativo: -οι- y -αι-",
      "contenido": [
        {
          "tipo": "parrafo",
          "texto": "El optativo se caracteriza por dos infijos principales: -οι- (en voz activa, presente) y -αι- (en voz activa, aoristo). Estos infijos distinguen el optativo de otros modos."
        },
        {
          "tipo": "titulo-seccion",
          "nivel": 4,
          "texto": "Estructura del Optativo Presente Activo"
        },
        {
          "tipo": "lista",
          "items": [
            "TEMA + -οι- + DESINENCIA SECUNDARIA",
            "λύ-οι-μι (yo pudiera disolver) - 1ª singular",
            "λύ-οι-ς (tú pudieras disolver) - 2ª singular"
          ]
        }
      ]
    },
    {
      "id": "optativo-paradigma",
      "tipo": "tabla-interactiva",
      "titulo": "Optativo Presente Activo: λύω (pudiera disolver, ojalá disuelva)",
      "descripcion": "Forma completa del optativo presente activo",
      "datos": {
        "columnas": [
          "Persona",
          "Singular",
          "Plural"
        ],
        "filas": [
          [
            "1ª",
            "λύ-οι-μι (yo pudiera)",
            "λύ-οι-μεν (nosotros pudiéramos)"
          ],
          [
            "2ª",
            "λύ-οι-ς (tú pudieras)",
            "λύ-οι-τε (vosotros pudierais)"
          ],
          [
            "3ª",
            "λύ-οι (él pudiera)",
            "λύ-οι-εν (ellos pudieran)"
          ]
        ]
      }
    },
    {
      "id": "optativo-aoristo",
      "tipo": "explicacion",
      "titulo": "Optativo Aoristo: -αι- Característica",
      "contenido": [
        {
          "tipo": "parrafo",
          "texto": "El aoristo optativo usa -αι- como infijo. Mantiene la sigma aorística y las desinencias secundarias."
        },
        {
          "tipo": "titulo-seccion",
          "nivel": 4,
          "texto": "Aoristo Optativo Activo"
        },
        {
          "tipo": "lista",
          "items": [
            "1ª Singular: λύ-σ-αι-μι (yo pudiera soltar)",
            "2ª Singular: λύ-σ-αι-ς (tú pudieras soltar)",
            "3ª Singular: λύ-σ-αι-ε (él pudiera soltar)",
            "1ª Plural: λύ-σ-αι-μεν (nosotros pudiéramos soltar)",
            "2ª Plural: λύ-σ-αι-τε (vosotros pudierais soltar)",
            "3ª Plural: λύ-σ-αι-εν (ellos pudieran soltar)"
          ]
        }
      ]
    },
    {
      "id": "optativo-usos",
      "tipo": "explicacion",
      "titulo": "Usos Principales del Optativo en el NT",
      "contenido": [
        {
          "tipo": "titulo-seccion",
          "nivel": 4,
          "texto": "1. Deseo Realizable"
        },
        {
          "tipo": "lista",
          "items": [
            "δόξαν ἐπιτυχεῖν (pudieran tener gloria) - deseo de lo que es realizable",
            "No es tan imposible como contrafáctico, pero es deseado"
          ]
        },
        {
          "tipo": "titulo-seccion",
          "nivel": 4,
          "texto": "2. Contrafáctico (Opuesto a la Realidad)"
        },
        {
          "tipo": "lista",
          "items": [
            "μὴ γένοιτο (¡que no sea! - pero tememos que pueda ser)",
            "Expresa un deseo que contradice lo que esperamos"
          ]
        },
        {
          "tipo": "titulo-seccion",
          "nivel": 4,
          "texto": "3. Condicionales Contrafácticas (con εἰ)"
        },
        {
          "tipo": "lista",
          "items": [
            "εἰ τοῦτο ἦν, πῶς ἂν οὕτως ἔχοι; (si esto fuera así, ¿cómo pudiera ser?)",
            "Usualmente con ἂν (partícula modal)"
          ]
        }
      ]
    },
    {
      "id": "optativo-medio-pasivo",
      "tipo": "explicacion",
      "titulo": "Optativo Medio y Pasivo",
      "contenido": [
        {
          "tipo": "parrafo",
          "texto": "El optativo medio mantiene -οι- pero usa desinencias medias (-μην, -σο, -το, etc.). El pasivo tiene su propia formación especial."
        },
        {
          "tipo": "titulo-seccion",
          "nivel": 4,
          "texto": "Ejemplos de Optativo Medio"
        },
        {
          "tipo": "lista",
          "items": [
            "1ª Singular: λύ-ο-ί-μην (yo pudiera liberarme)",
            "3ª Singular: λύ-ο-ί-το (él pudiera liberarse)"
          ]
        }
      ]
    }
  ],

  "prerequisitos": [
    "n1-l12"
  ],
  "objetivos": [
    "Entender el aspecto imperfectivo del imperfecto",
    "Conjugar verbos en imperfecto indicativo activo",
    "Diferenciar entre aoristo (acción puntual) e imperfecto (acción habitual)",
    "Reconocer el aumento temporal (ἠ-, ἐ-) en el imperfecto"
  ],
  "secciones": [
    {
      "id": "aspecto-imperfectivo",
      "tipo": "explicacion",
      "titulo": "El Aspecto Imperfectivo: Acción Incompleta",
      "contenido": [
        {
          "tipo": "parrafo",
          "texto": "El imperfecto presenta la acción como INCOMPLETA, habitual o en progreso. No nos dice cuándo empieza ni cuándo termina la acción; solo describe lo que estaba sucediendo."
        },
        {
          "tipo": "titulo-seccion",
          "nivel": 4,
          "texto": "Diferencia entre Aoristo e Imperfecto"
        },
        {
          "tipo": "lista",
          "items": [
            "AORISTO: ἔλυσε (soltó) - acción completa, puntual, momentánea",
            "IMPERFECTO: ἔλυε (soltaba, estaba soltando) - acción habitual, repetida o en progreso"
          ]
        },
        {
          "tipo": "cita",
          "texto": "καί ἐλάλει αὐτοῖς",
          "transliteracion": "kai elalei autois",
          "traduccion": "y les hablaba (repetidamente, en progreso)",
          "referencia": "Lucas 5:3",
          "clase": "normal"
        }
      ]
    },
    {
      "id": "aumento-temporal",
      "tipo": "explicacion",
      "titulo": "El Aumento Temporal (Augment)",
      "contenido": [
        {
          "tipo": "parrafo",
          "texto": "El imperfecto (y otros tiempos pasados) añaden un AUMENTO al inicio del verbo. Este es un prefijo que marca que la acción es pasada."
        },
        {
          "tipo": "titulo-seccion",
          "nivel": 4,
          "texto": "Tipos de Aumento"
        },
        {
          "tipo": "lista",
          "items": [
            "AUMENTO SILÁBICO: verbos que comienzan con consonante → agregar ἐ",
            "  λύω → ἔ-λυ-ον (soltaba)",
            "AUMENTO TEMPORAL: verbos que comienzan con vocal → la vocal se alarga",
            "  ἀγαπάω → ἠγάπα (amaba)"
          ]
        }
      ]
    },
    {

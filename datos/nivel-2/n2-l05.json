  "objetivos": [
    "Entender el futuro como acción venidera",
    "Formar y conjugar el futuro 1º (sigmático)",
    "Reconocer el futuro 2º (ático)",
    "Comprender las diferencias entre futuro 1º y futuro 2º"
  ],
  "secciones": [
    {
      "id": "futuro-intro",
      "tipo": "explicacion",
      "titulo": "El Futuro: Acción Venidera",
      "contenido": [
        {
          "tipo": "parrafo",
          "texto": "El futuro en griego presenta una acción que se espera ocurra en el tiempo venidero. A diferencia del presente, no expresa la actualidad; a diferencia del aoristo, no cuenta lo que sucedió."
        },
        {
          "tipo": "nota",
          "titulo": "Nota sobre Modalidad",
          "texto": "En el NT, el futuro a menudo tiene un matiz de promesa o intención, especialmente cuando aparece en dichos proféticos o en las palabras de Jesús. No es simplemente tiempo mecánico."
        }
      ]
    },
    {
      "id": "futuro-primero",
      "tipo": "explicacion",
      "titulo": "Futuro 1º (Sigmático): La Forma Regular",
      "contenido": [
        {
          "tipo": "parrafo",
          "texto": "El futuro 1º es la forma regular, caracterizada por la inserción de SIGMA (-σ-) entre el tema y la desinencia. Las desinencias son las mismas que en presente indicativo activo."
        },
        {
          "tipo": "titulo-seccion",
          "nivel": 4,
          "texto": "Formación del Futuro 1º"
        },
        {
          "tipo": "lista",
          "items": [
            "TEMA + SIGMA (-σ-) + DESINENCIAS PRIMARIAS ACTIVAS",
            "λύω (soltaré) → λύ-σ-ω = tema + sigma + desinencia 1ª sing.",
            "NO lleva aumento (no es pasado, es futuro)"
          ]
        }
      ]
    },
    {
      "id": "futuro-primera-paradigma",
      "tipo": "tabla-interactiva",
      "titulo": "Futuro 1º Indicativo Activo: λύω (soltaré)",

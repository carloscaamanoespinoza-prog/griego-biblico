      "tipo": "explicacion",
      "titulo": "Futuro 2º (Ático): La Forma Irregular",
      "contenido": [
        {
          "tipo": "parrafo",
          "texto": "El futuro 2º es una forma menos común que no usa sigma. Tiene un tema modificado y desinencias del presente. Solo algunos verbos lo utilizan en el NT."
        },
        {
          "tipo": "nota",
          "titulo": "Futuro 2º en el NT",
          "texto": "Algunos verbos como ὁράω (veo) usan futuro 2º: ὄψομαι (veré). Otros como ἔχω usan futuro 1º: ἕξω (tendré)."
        },
        {
          "tipo": "titulo-seccion",
          "nivel": 4,
          "texto": "Ejemplos de Futuro 2º"
        },
        {
          "tipo": "lista",
          "items": [
            "ὁράω (veo) → ὄψ-ο-μαι (veré - nota la voz media en forma)",
            "εἰμί (soy) → ἔσ-ο-μαι (seré - completamente irregular)",
            "ἔρχομαι (vengo) → ἐλεύσ-ο-μαι (vendré)"
          ]
        }
      ]

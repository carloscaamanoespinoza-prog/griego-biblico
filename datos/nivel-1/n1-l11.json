    {
      "id": "voces-verbales",
      "tipo": "explicacion",
      "titulo": "Las Tres Voces Verbales",
      "contenido": [
        {
          "tipo": "parrafo",
          "texto": "En griego hay TRES voces verbales, no solo dos como en español. Cada una tiene un significado y uso diferente."
        },
        {
          "tipo": "titulo-seccion",
          "nivel": 4,
          "texto": "Voz Activa"
        },
        {
          "tipo": "lista",
          "items": [
            "El sujeto realiza la acción",
            "Ejemplo: ὁ δοῦλος λύει τὸν δεσμόν (el esclavo libera la cuerda)"
          ]
        },
        {
          "tipo": "titulo-seccion",
          "nivel": 4,
          "texto": "Voz Media"
        },
        {
          "tipo": "lista",
          "items": [
            "El sujeto realiza la acción para sí mismo o es afectado por ella",
            "Ejemplo: ὁ δοῦλος λύεται τὸν δεσμόν (el esclavo se libera de la cuerda)"
          ]
        },
        {
          "tipo": "titulo-seccion",
          "nivel": 4,
          "texto": "Voz Pasiva"
        },
        {
          "tipo": "lista",
          "items": [
            "El sujeto recibe la acción",
            "En presente, usa las mismas terminaciones que la voz media",
            "Ejemplo: ὁ δεσμὸς λύεται (la cuerda es liberada)"
          ]
        }
      ]
    },

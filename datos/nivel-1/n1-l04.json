  "secciones": [
    {
      "id": "funcion-articulo",
      "tipo": "explicacion",
      "titulo": "¿Qué es el Artículo Definido en Griego?",
      "contenido": [
        {
          "tipo": "parrafo",
          "texto": "El artículo definido en griego (equivalente a 'el', 'la', 'los', 'las' en español) es una de las palabras más frecuentes e importantes. Cumple varias funciones fundamentales."
        },
        {
          "tipo": "titulo-seccion",
          "nivel": 4,
          "texto": "Funciones principales"
        },
        {
          "tipo": "lista",
          "items": [
            "Determina el sustantivo, indicando que es específico (como el artículo español)",
            "Nos indica el GÉNERO del sustantivo (masculino, femenino o neutro)",
            "Nos indica el NÚMERO (singular o plural)",
            "Nos indica el CASO (nominativo, acusativo, genitivo o dativo)",
            "Actúa como puente entre el sustantivo y los adjetivos"
          ]
        },
        {
          "tipo": "parrafo",
          "texto": "La importancia del artículo en griego no puede exagerarse. En muchas frases, el artículo es la única pista de qué caso se está usando en un sustantivo."
        }
      ]
    },
